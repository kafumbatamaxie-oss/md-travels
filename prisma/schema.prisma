generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


/****************                     ********
 * ================= CUSTOMERS =================
 */
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?

  quotes    Quote[]
  bookings  Booking[]

  createdAt DateTime @default(now())
}


/**
 * ================= SERVICES =================
 */
model Service {
  id            String   @id @default(uuid())
  name          String
  description   String?
  pricingModel  PricingModel

  basePrice     Float?
  pricePerKm    Float?
  pricePerDay   Float?

  vehicles      ServiceVehicle[]
  quoteItems    QuoteItem[]   // ✅ ADD THIS
  bookings      Booking[]     // recommended
  createdAt     DateTime @default(now())
}

enum PricingModel {
  AIRPORT_TRANSFER
  SINGLE_TRIP
  DAILY_TRIP
  HALF_DAY_TRIP
  HOURLY
}

enum ServiceCategory {
  TRANSFER
  SHUTTLE
  TOUR
  RENTAL
}




/**
 * ================= VEHICLES =================
 */

model Vehicle {
  id            String   @id @default(uuid())

  name          String
  type          String
  capacity      Int

  basePrice     Float?
  perKmPrice    Float?
  perDayPrice   Float?

  status        VehicleStatus

  bookings      Booking[]
  quoteItems    QuoteItem[]   // ✅ ADD THIS
  services      ServiceVehicle[]

  images        VehicleImage[]   // 👈 ADD THIS

  createdAt     DateTime @default(now())
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  DISABLED
}

/**
  * =============Vehicle Image
*/
model VehicleImage {
  id        String   @id @default(uuid())

  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  url       String
  publicId  String

  order     Int      @default(0)

  createdAt DateTime @default(now())

  @@index([vehicleId])
}



model ServiceVehicle {
  serviceId String
  vehicleId String

  service   Service @relation(fields: [serviceId], references: [id])
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  @@id([serviceId, vehicleId])
}




/**
 * ================= DRIVERS =================
 */

model Driver {
  id        String   @id @default(uuid())

  name      String
  phone     String

  license   String?
  licenseType String?

  status    DriverStatus

  maxDailyHours Int   @default(10)

  bookings  Booking[]

  createdAt DateTime @default(now())
}

enum DriverStatus {
  ACTIVE
  OFF_DUTY
  ON_LEAVE
  SUSPENDED
}




/**
 * ================= QUOTES =================
 */
model Quote {
  id           String   @id @default(uuid())

  quoteNumber  String   @unique

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  status       QuoteStatus

  totalPrice   Float

  expiresAt    DateTime?

  items        QuoteItem[]

  bookings     Booking[]   // ← ADD THIS (fix)

  invoices     Invoice[]

  createdAt    DateTime @default(now())

  @@index([customerId])
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
}

model QuoteItem {
  id          String @id @default(uuid())

  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id])

  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id])

  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])

  description String?

  passengers  Int

  pickup      String?
  destination String?

  startDate   DateTime?
  endDate     DateTime?

  distanceKm  Float?

  price       Float
}


/**
 * ================= BOOKING =================
 */

model Booking {
  id           String @id @default(uuid())

  bookingRef   String @unique

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  vehicleId    String
  vehicle      Vehicle @relation(fields: [vehicleId], references: [id])

  driverId     String?
  driver       Driver? @relation(fields: [driverId], references: [id])

  serviceId    String
  service      Service @relation(fields: [serviceId], references: [id])

  quoteId      String?
  quote        Quote? @relation(fields: [quoteId], references: [id])

  passengers   Int

  pickup       String
  destination  String?

  startDate    DateTime
  endDate      DateTime?

  distanceKm   Float?

  price        Float

  status       BookingStatus

  invoices     Invoice[]

  createdAt    DateTime @default(now())

  @@index([vehicleId, startDate, endDate])   // ADD THIS
}


enum BookingStatus {
  QUOTE_HOLD
  RESERVED
  CONFIRMED
  COMPLETED
  CANCELLED
}


/**
 * ================= INVOICE =================
 */

model Invoice {
  id         String  @id @default(uuid())

  quoteId    String?
  quote      Quote?  @relation(fields: [quoteId], references: [id])

  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])

  amount     Float

  pdfUrl     String?

  issuedAt   DateTime @default(now())
}